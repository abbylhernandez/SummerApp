{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "STM32: Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "STM32: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/Debug",
                "--parallel"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "STM32: Configure (Debug)",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "STM32: Flash (ST-Link)",
            "type": "shell",
            "command": "C:/ST/STM32CubeIDE_2.1.1/STM32CubeIDE/plugins/com.st.stm32cube.ide.mcu.externaltools.cubeprogrammer.win32_2.2.400.202601091506/tools/bin/STM32_Programmer_CLI.exe",
            "args": [
                "-c",
                "port=SWD",
                "-w",
                "${workspaceFolder}/build/Debug/signalsimulator.elf",
                "-v",
                "-rst"
            ],
            "dependsOn": "STM32: Build",
            "problemMatcher": []
        },
        {
            "label": "STM32: Build and Flash",
            "dependsOrder": "sequence",
            "dependsOn": [
                "STM32: Build",
                "STM32: Flash (ST-Link)"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
