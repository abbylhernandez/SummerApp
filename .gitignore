.venv/
.vscode/settings.json
CleanData/

# ==========================================
# DATA FILES (Ignore large data files)
# ==========================================
prune*
LDA_BASE_size*

# ==========================================
# VIDEO FILES (Ignore all video recordings)
# ==========================================
*.avi
*.mp4
*.mov
*.mkv
*.wmv
*.webm
*.mpg
*.mpeg


# ==========================================
# TEXT FILES (Ignore raw EMG data logs)
# ==========================================
*.txt
*.csv

# ==========================================
# PYTHON CACHE
# ==========================================
/__pycache__
*.pyc

# ==========================================
# STM32CubeIDE / Eclipse
# ==========================================

# Workspace metadata (DO NOT upload)
.metadata/
.settings/
*.log
*.tmp
*.launch

# ==========================================
# BUILD FOLDERS (Auto-generated)
# ==========================================
Debug/
Release/
build/

# ==========================================
# COMPILED / BINARY FILES
# ==========================================
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.list

# ==========================================
# ARCHIVES
# ==========================================
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ==========================================
# CMake (if used)
# ==========================================
CMakeFiles/
CMakeCache.txt

# ==========================================
# OS FILES
# ==========================================
.DS_Store
__MACOSX/
._*
Thumbs.db
